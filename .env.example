# ЮKassa — берёте из личного кабинета yookassa.ru
YUKASSA_SHOP_ID=ваш_shop_id
YUKASSA_SECRET=ваш_секретный_ключ

# Ваш Gmail (с которого будут уходить письма)
EMAIL_FROM=ваш@gmail.com
EMAIL_PASSWORD=пароль_приложения_google  # не обычный пароль, а App Password

# URL вашего сайта (где развёрнут фронтенд)
SITE_URL=https://ваш-домен.com
